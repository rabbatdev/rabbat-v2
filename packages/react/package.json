{
  "name": "@rabbat/react",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./entry-client": {
      "types": "./dist/entry-client.d.ts",
      "default": "./dist/entry-client.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@rabbat/protocol": "workspace:*",
    "@rabbat/functions": "workspace:*",
    "@rabbat/client": "workspace:*",
    "@rabbat/router": "workspace:*",
    "@rabbat/vite-react": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "react": "19.2.0",
    "@types/react": "19.2.2",
    "react-dom": "19.2.0",
    "@types/react-dom": "19.2.1",
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.0"
  }
}
