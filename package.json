{
  "name": "rabbat-v2-monorepo",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "description": "Rabbat v2 — a reactive, horizontally-scalable database on Cloudflare R2 + Durable Objects, built with Effect v4. Incremental sync, bi-directional infinite pagination, SSR preload, and query caching.",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260629.1",
    "turbo": "2.10.0",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "effect": "4.0.0-beta.91"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "workerd",
      "esbuild",
      "sharp"
    ]
  }
}
